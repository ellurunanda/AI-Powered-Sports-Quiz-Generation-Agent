# Application
APP_NAME="AI Powered Sports Quiz Generation Agent"
ENVIRONMENT="development"
LOG_LEVEL="INFO"
LLM_PROVIDER="gemini"

# Gemini
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_FALLBACK_MODELS="gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash,gemini-1.5-flash-8b"

# OpenAI (used when LLM_PROVIDER="openai")
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Retrieval and generation
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
CHROMA_COLLECTION_NAME="sports_facts"
TOP_K_HISTORICAL=6
TOP_K_NEWS=5
QUIZ_QUESTION_COUNT=5
REQUEST_TIMEOUT_SECONDS=30
DUCKDUCKGO_REGION="wt-wt"
NEWS_CACHE_TTL_SECONDS=300
